{
  "name": "nexora-agent",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace frontend\" \"npm run dev:backend\"",
    "dev:backend": ".venv/bin/uvicorn app.main:app --reload --app-dir backend --host 0.0.0.0 --port 8000",
    "build": "npm run build --workspace frontend",
    "lint": "npm run lint --workspace frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
